{
  "name": "blender-nodes-r3f",
  "version": "0.1.0",
  "description": "Blender-compatible node system (Shader / Geometry / Compositor / Texture) for three.js / react-three-fiber",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p . --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p . --noEmit",
    "test": "tsx scripts/smoketest.ts",
    "ci": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "@xyflow/react": "^12.3.5",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.2",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
